ейдя от бумажных документов к цифровым и от централизованной модели к распределенной сети. Это руководство призвано информировать сообщество АГРИС, в частности тех, кто использует базу данных АГРИС для поиска научной литературы по сельскому хозяйству и продовольствию, об оптимальных способах взаимодействия с базой данных и поиска в ней.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;8f249314-744f-448c-8bb4-70ca0aff1ad0&q;,&q;language&q;:null,&q;value&q;:&q;24 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;454a7842-22b7-4db0-b029-833dc4a33fe0&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cc1063ru&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.url&q;:[{&q;uuid&q;:&q;4b381b05-ef43-44c5-ac03-712b34d02975&q;,&q;language&q;:null,&q;value&q;:&q;http://www.fao.org/3/cc1063ru/cc1063ru.pdf&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;98a9d575-12b0-4ef3-a0f2-a40f8906820e&q;,&q;language&q;:null,&q;value&q;:&q;Russian&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;c497d1e1-1e5a-4da4-9f35-6ce2b3b8080c&q;,&q;language&q;:null,&q;value&q;:&q;ФАО ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;e729ea2e-a118-4b8e-8c86-aa13567938bb&q;,&q;language&q;:null,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.license&q;:[{&q;uuid&q;:&q;ad2fd644-9af1-49e6-8e9e-690417cec14e&q;,&q;language&q;:null,&q;value&q;:&q;CC BY NC SA 3.0 IGO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title&q;:[{&q;uuid&q;:&q;a63398c9-22bd-4d47-a8a8-a6a3b5ee7998&q;,&q;language&q;:null,&q;value&q;:&q;АГРИС Международная информационная система по сельскохозяйственным наукам и технологиям&q;,&q;place&q;:0,&q;authority&q;:nu