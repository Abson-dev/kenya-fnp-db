q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.description.abstract&q;:[{&q;uuid&q;:&q;8952168f-856c-43f6-93b2-8d8930ff2621&q;,&q;language&q;:null,&q;value&q;:&q;النظام الدولي للإعلام عن العلوم والتكنولوجيا هو أحد أكثر قواعد البيانات شمولاً للأدب العلمي الغذائي والزراعي في جميع أنحاء العالم. يمكن الوصول إليه من خلال بوابة الويب، حيث تتوفر ملايين السجلات الببليوغرافية بأكثر من 90 لغة مختلفة مجانًا للمستخدمين العالميين. شبكة دولية من مزودي البيانات تتضمن الناشرون والحكومات والمنظمات، ومعلومات المتطوعين (البيانات الوصفية) حول المنشورات العلمية. هذه السجلات متوفرة بتنسيقات متعددة اللغات وغالباً ما تتضمن روابط نصية كاملة لربط المستخدمين المواد المطبوعة العلمية في جميع أنحاء العالم على مدى السنوات الأخيرة، تطورلنظام الدولي للإعلام عن العلوم والتكنولوجيا ليصبح مصدر معلومات معترف به في جميع أنحاء العالم من خلالالانتقال من النظام الورقي إلى النظام الرقمي، ومن النموذج المركزي إلى الشبكة الموزعة. يهدف هذا الدليل إلى تحديث مجتمع النظام الدولي للإعلام عن العلوم والتكنولوجيا، لا سيما أولئك الذين يستخدمون قاعدة بيانات النظام الدولي للإعلام عن العلوم والتكنولوجيا للعثور على المؤلفات العلمية حول الأغذية والزراعة ، حول أفضل الطرق للتعامل مع قاعدة البيانات والبحث فيها&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;5c36fd5f-eaac-4efc-b38c-ef1a9509c538&q;,&q;language&q;:null,&q;value&q;:&q;24 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;d88357dc-2af4-46ec-9abe-5eaaf580fa30&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cc1063ar&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.url&q;:[{&q;uuid&q;:&q;291a9c5b-5ac4-4b97-9530-662ef962fb16&q;,&q;language&q;:null,&q;value&q;:&q;http://www.fao.org/3/cc1063ar/cc1063ar.pdf&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;ae4406ce-13ab-47a7-b4b1-8e8cfce8ec56&q;,&q;language&q;:null,&q;value&q;:&q;A