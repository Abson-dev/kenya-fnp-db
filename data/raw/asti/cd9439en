nt 2015 purchasing power parities) on public agricultural research.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;4e275a37-05b9-49d1-a0c9-0a2f1681e5cc&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;9 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.eissn&q;:[{&q;uuid&q;:&q;ad02fd64-5ba8-4101-a6ca-8aa541bc064c&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2709-0078&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.issn&q;:[{&q;uuid&q;:&q;cd544267-4ef8-40e4-91f9-dbd59374f744&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;2709-006X&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;9f8fa4d7-a758-48cf-8275-11c48bf6e852&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd9439en&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;ada130c2-81f6-4883-b025-e22e89b0c716&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;English&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;88c3faee-aa20-4c80-a49d-73017dfd9008&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.ispartofseries&q;:[{&q;uuid&q;:&q;c50fab84-ef1b-4a41-9f36-11b8e361cfcb&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAOSTAT Analytical Briefs&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.relation.number&q;:[{&q;uuid&q;:&q;8fd5fbb3-eddc-4f30-a120-14dfd49ed465&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;No. 124&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;1bc75091-daef-41b4-b397-0308feef57a1&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.license&q;:[{&q;uuid&q;:&q;91776534-0bae-42f1-80ea-97e86b9c1137&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;CC BY 4.0&q;,&