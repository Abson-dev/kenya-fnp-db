包容和公平的农业粮食体系，不让任何人掉队的持久承诺的见证。&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.format.numberofpages&q;:[{&q;uuid&q;:&q;00fd6acd-9bd7-4a8e-ad3c-2a0652fc739c&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;162 p.&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.isbn&q;:[{&q;uuid&q;:&q;fbf6300e-e3aa-49cb-8c4b-5ece3b5d63aa&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;978-92-5-140121-7&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.identifier.uri&q;:[{&q;uuid&q;:&q;4b312787-2113-49cb-8459-547351f7e070&q;,&q;language&q;:null,&q;value&q;:&q;https://openknowledge.fao.org/handle/20.500.14283/cd6837zh&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.language.iso&q;:[{&q;uuid&q;:&q;6cfb5a93-d518-4fed-9f25-e1c5acd7ea4a&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Chinese&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.publisher&q;:[{&q;uuid&q;:&q;f1f85674-a51a-42fa-aa89-08bd7aac01c1&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;粮农组织 ;&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.copyright&q;:[{&q;uuid&q;:&q;e53bdcb2-0f48-4dfb-ad38-ef8350185316&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;FAO&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.rights.license&q;:[{&q;uuid&q;:&q;8d352889-26df-450a-bbb6-a90416ad668f&q;,&q;language&q;:null,&q;value&q;:&q;CC BY 4.0&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title&q;:[{&q;uuid&q;:&q;69bef54a-e600-4192-92c1-a75c1ad91ab5&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;砥砺奋进结硕果，四个更好谱华章&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.englishtranslation&q;:[{&q;uuid&q;:&q;d371a2ee-7602-47c7-aaad-2134373a5447&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;Picturing progress&q;,&q;place&q;:0,&q;authority&q;:null,&q;confidence&q;:-1}],&q;dc.title.subtitle&q;:[{&q;uuid&q;:&q;3bd43f98-2e4b-49d7-a793-aa009129594a&q;,&q;language&q;:&q;&q;,&q;value&q;:&q;联合国粮食及农业组织成立八十周年纪念图册&q;,&q;place&q;:0,&q;authority&q;